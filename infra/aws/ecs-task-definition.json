{
  "family": "glass-market-daily",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::ACCOUNT_ID:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::ACCOUNT_ID:role/ecsTaskRole",
  "containerDefinitions": [
    {
      "name": "glass-market-daily",
      "image": "ACCOUNT_ID.dkr.ecr.ap-northeast-1.amazonaws.com/glass-market-daily:latest",
      "essential": true,
      "environment": [
        {"name": "MODEL", "value": "opus"},
        {"name": "MAX_BUDGET", "value": "5"}
      ],
      "secrets": [
        {
          "name": "ANTHROPIC_API_KEY",
          "valueFrom": "arn:aws:secretsmanager:ap-northeast-1:ACCOUNT_ID:secret:anthropic-api-key"
        },
        {
          "name": "GDRIVE_SERVICE_ACCOUNT",
          "valueFrom": "arn:aws:secretsmanager:ap-northeast-1:ACCOUNT_ID:secret:gdrive-service-account"
        },
        {
          "name": "GDRIVE_FOLDER_ID",
          "valueFrom": "arn:aws:secretsmanager:ap-northeast-1:ACCOUNT_ID:secret:gdrive-folder-id"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/glass-market-daily",
          "awslogs-region": "ap-northeast-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
